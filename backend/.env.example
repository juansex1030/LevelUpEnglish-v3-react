PORT=3000
SECRET_KEY=your-super-secret-key-change-me
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Required connection string
# Use Supabase Session Pooler for Vercel/IPv4 environments.
# Get the exact value from Supabase: Project Settings > Database > Connection string > Session pooler.
# Typical format:
# postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# Supabase typically requires SSL
PGSSL=true
