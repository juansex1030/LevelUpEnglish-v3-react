

# PostgreSQL
# Option 1 (recommended): use a full connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/levelupenglish

# Option 2: explicit PG vars (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=levelupenglish

# Set to true in providers that require SSL (e.g. Render)
PGSSL=false
